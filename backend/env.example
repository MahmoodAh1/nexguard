# NexGuard backend configuration (env-driven, 12-factor).
# Copy to `.env`:  cp env.example .env
# NEVER commit a real `.env`. No value here is a real secret.

# ── App ────────────────────────────────────────────────
NEXGUARD_ENV=development                     # development | production | test
NEXGUARD_DEBUG=true
NEXGUARD_LOG_LEVEL=INFO
NEXGUARD_LOG_JSON=false                       # true = JSON logs (prod)

# ── Database ───────────────────────────────────────────
# dev default is an on-disk SQLite file; prod uses postgres+asyncpg.
NEXGUARD_DATABASE_URL=sqlite+aiosqlite:///./nexguard.db
# NEXGUARD_DATABASE_URL=postgresql+asyncpg://nexguard:nexguard@postgres:5432/nexguard

# ── Redis (event bus / cache / rate-limit) ─────────────
NEXGUARD_REDIS_URL=redis://localhost:6379/0
NEXGUARD_EVENT_BUS=memory                     # memory | redis

# ── Security ───────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
NEXGUARD_JWT_SECRET=change-me-in-production-use-a-48-byte-random-secret
NEXGUARD_JWT_ALGORITHM=HS256
NEXGUARD_ACCESS_TOKEN_TTL_SECONDS=900         # 15 min
NEXGUARD_REFRESH_TOKEN_TTL_SECONDS=1209600    # 14 days
NEXGUARD_RATE_LIMIT_PER_MINUTE=120
NEXGUARD_AUTH_RATE_LIMIT_PER_MINUTE=10

# ── CORS ───────────────────────────────────────────────
NEXGUARD_CORS_ORIGINS=http://localhost:3000

# ── LLM (Ollama, local only — no cloud) ────────────────
NEXGUARD_LLM_PROVIDER=stub                     # stub | ollama
NEXGUARD_OLLAMA_BASE_URL=http://localhost:11434
NEXGUARD_OLLAMA_MODEL=llama3.1
NEXGUARD_LLM_TIMEOUT_SECONDS=60

# ── Detection ──────────────────────────────────────────
NEXGUARD_ENSEMBLE_SEQ_WEIGHT=0.6
NEXGUARD_ENSEMBLE_STAT_WEIGHT=0.4
NEXGUARD_ALERT_THRESHOLD=0.5
NEXGUARD_MODEL_ARTIFACT_DIR=./models/artifacts
